<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gloss.chatroom.mapper.UserMapper">
    <insert id="insert">
        insert into user(id,username,password) values (null,#{username},#{password});
    </insert>

    <select id="selectByUserName" resultType="com.gloss.chatroom.model.User">
        select * from user which #{username} = username;
    </select>

</mapper>